# icmp flood (ping flood ddos)
alert icmp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICADS ICMP Flood Detected - Possible DDoS"; itype:8; threshold:type both, track by_src, count 50, seconds 10; classtype:attempted-dos; sid:1000001; rev:1;)

# tcp syn flood
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICADS TCP SYN Flood Detected"; flags:S,12; threshold:type both, track by_src, count 100, seconds 10; classtype:attempted-dos; sid:1000002; rev:1;)

# udp flood
alert udp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICADS UDP Flood Detected"; threshold:type both, track by_src, count 200, seconds 10; classtype:attempted-dos; sid:1000003; rev:1;)

# horizontal port scan
alert tcp $EXTERNAL_NET any -> $HOME_NET any (msg:"ICADS Port Scan Detected - Horizontal Sweep"; flags:S,12; threshold:type both, track by_src, count 25, seconds 30; classtype:attempted-recon; sid:1000004; rev:1;)

# http flood (layer 7 ddos)
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (msg:"ICADS HTTP Flood Detected - App Layer DDoS"; flow:to_server,established; threshold:type both, track by_src, count 100, seconds 10; classtype:attempted-dos; sid:1000005; rev:1;)

# dns amplification
alert udp any 53 -> $HOME_NET any (msg:"ICADS DNS Amplification Attack Suspected"; dsize:>512; threshold:type both, track by_dst, count 50, seconds 10; classtype:attempted-dos; sid:1000006; rev:1;)

# large icmp packet (smurf indicator)
alert icmp any any -> $HOME_NET any (msg:"ICADS Large ICMP Packet - Possible Smurf Attack"; dsize:>1000; classtype:attempted-dos; sid:1000007; rev:1;)

# outbound traffic to known c2 ports
alert tcp $HOME_NET any -> $EXTERNAL_NET [4444,5555,6666,7777,8888,1234,31337] (msg:"ICADS Suspicious Outbound Traffic to Known C2 Port"; flow:to_server,established; classtype:trojan-activity; sid:1000008; rev:1;)

# ssh brute force
alert tcp $EXTERNAL_NET any -> $HOME_NET 22 (msg:"ICADS SSH Brute Force Detected"; flags:S,12; threshold:type both, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:1000009; rev:1;)

# outbound ddos flooder detection
alert tcp $HOME_NET any -> $EXTERNAL_NET any (msg:"ICADS Outbound DDoS Flooder Detected"; flags:S,12; threshold:type both, track by_src, count 200, seconds 10; classtype:attempted-dos; sid:1000010; rev:1;)
